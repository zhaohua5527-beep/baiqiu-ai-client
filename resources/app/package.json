{
  "name": "baiqiu-ai",
  "version": "1.1.20",
  "description": "Baiqiu AI desktop client with embedded OpenClaw control",
  "main": "main.js",
  "private": true,
  "dependencies": {
    "adler-32": "^1.3.1",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5"
  },
  "productName": "白球AI",
  "build": {
    "appId": "com.baiqiu.ai",
    "productName": "白球AI",
    "directories": { "output": "dist" },
    "win": { "target": ["nsis", "zip"], "icon": "assets/icon.ico" },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "白球AI"
    },
    "artifactName": "BaiqiuAI-Setup-${version}.${ext}",
    "electronVersion": "35.7.5"
  }
}
